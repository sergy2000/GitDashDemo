<Window x:Class="GitDashDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gitdashdemo="clr-namespace:GitDashDemo" d:DataContext="{d:DesignInstance Type=gitdashdemo:GitMainViewModel}"
        mc:Ignorable="d"
       Title="DevLink" Height="500" Width="900" MinWidth="700" MinHeight="450"
        Background="#FFF5F7FA" FontFamily="Segoe UI">


    <Window.Resources>
        <!-- Accent Brush -->
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC" />
        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004578" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#888" BlurRadius="10" ShadowDepth="2" Opacity="0.2" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Search -->
            <RowDefinition Height="Auto" />
            <!-- Profile -->
            <RowDefinition Height="Auto" />
            <!-- Repos header -->
            <RowDefinition Height="*" />
            <!-- Repos list -->
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Width="250"  />
            <Button Content="Search" Command="{Binding btnSearch}" />
        </StackPanel>

        <!-- Profile Card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Avatar -->
                <Border Width="150" Height="150" CornerRadius="75" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top" ClipToBounds="True">
                    <Image Source="{Binding User.avatar_url}" Stretch="UniformToFill" />
                </Border>

                <!-- Details -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="{Binding User.login}" FontSize="28" FontWeight="Bold" Foreground="#333" />
                    <TextBlock Text="{Binding User.bio}" FontSize="15" Foreground="#666" TextWrapping="Wrap" Margin="0,8,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Followers:" FontWeight="SemiBold" Foreground="#333" />
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="4,2" Margin="6,0,0,0">
                            <TextBlock Text="{Binding User.follower}" Foreground="White" FontSize="14" />
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Public Repos:" FontWeight="SemiBold" Foreground="#333" />
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="4,2" Margin="6,0,0,0">
                            <TextBlock Text="{Binding User.public_repos}" Foreground="White" FontSize="14" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Repos Header -->
        <TextBlock Grid.Row="2" Text="Public Repositories" FontSize="20" FontWeight="Bold" Margin="0,20,0,8" />

        <!-- Repos List -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Repo}" Margin="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="8" CornerRadius="4" Background="#FAFAFA">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#555" TextWrapping="Wrap" MaxHeight="40" />
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Margin="0,0,12,0"><Run Text="★"/> <Run Text="{Binding Stars}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,12,0"><Run Text="🍴"/><Run Text="{Binding Forks}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,12,0"><Run Text="📝"/><Run Text="{Binding Language}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:MM/dd/yyyy}'}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
    </Window>